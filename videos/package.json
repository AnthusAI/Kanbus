{
  "name": "kanbus-videos",
  "version": "1.0.0",
  "private": true,
  "description": "VideoML videos about Kanbus",
  "scripts": {
    "generate": "vml generate content/ && npm run sync:public",
    "render": "bash scripts/render-all.sh",
    "bundle:components": "npx tsx scripts/bundle-browser-components.ts",
    "sync:public": "for d in ../src/videos/*/; do id=$(basename $d); cp $d$id.timing.xml ../apps/kanb.us/public/videoml/$id.timing.xml 2>/dev/null; cp $d$id.script.json ../apps/kanb.us/public/videoml/$id.script.json 2>/dev/null; done && cp ../public/videoml/*.wav ../apps/kanb.us/public/videoml/",
    "vml:render:intro": "vml render --script ../src/videos/intro/intro.script.json --timeline ../src/videos/intro/intro.timeline.json --audio ../public/videoml/intro.wav --frames out/frames/intro --out out/intro.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:core-management": "vml render --script ../src/videos/core-management/core-management.script.json --timeline ../src/videos/core-management/core-management.timeline.json --audio ../public/videoml/core-management.wav --frames out/frames/core-management --out out/core-management.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:jira-sync": "vml render --script ../src/videos/jira-sync/jira-sync.script.json --timeline ../src/videos/jira-sync/jira-sync.timeline.json --audio ../public/videoml/jira-sync.wav --frames out/frames/jira-sync --out out/jira-sync.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:local-tasks": "vml render --script ../src/videos/local-tasks/local-tasks.script.json --timeline ../src/videos/local-tasks/local-tasks.timeline.json --audio ../public/videoml/local-tasks.wav --frames out/frames/local-tasks --out out/local-tasks.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:beads-compatibility": "vml render --script ../src/videos/beads-compatibility/beads-compatibility.script.json --timeline ../src/videos/beads-compatibility/beads-compatibility.timeline.json --audio ../public/videoml/beads-compatibility.wav --frames out/frames/beads-compatibility --out out/beads-compatibility.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:virtual-projects": "vml render --script ../src/videos/virtual-projects/virtual-projects.script.json --timeline ../src/videos/virtual-projects/virtual-projects.timeline.json --audio ../public/videoml/virtual-projects.wav --frames out/frames/virtual-projects --out out/virtual-projects.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:vscode-plugin": "vml render --script ../src/videos/vscode-plugin/vscode-plugin.script.json --timeline ../src/videos/vscode-plugin/vscode-plugin.timeline.json --audio ../public/videoml/vscode-plugin.wav --frames out/frames/vscode-plugin --out out/vscode-plugin.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:policy-as-code": "vml render --script ../src/videos/policy-as-code/policy-as-code.script.json --timeline ../src/videos/policy-as-code/policy-as-code.timeline.json --audio ../public/videoml/policy-as-code.wav --frames out/frames/policy-as-code --out out/policy-as-code.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:lifecycle-hooks": "vml render --script ../src/videos/lifecycle-hooks/lifecycle-hooks.script.json --timeline ../src/videos/lifecycle-hooks/lifecycle-hooks.timeline.json --audio ../public/videoml/lifecycle-hooks.wav --frames out/frames/lifecycle-hooks --out out/lifecycle-hooks.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js",
    "vml:render:realtime-collaboration": "vml render --script ../src/videos/realtime-collaboration/realtime-collaboration.script.json --timeline ../src/videos/realtime-collaboration/realtime-collaboration.timeline.json --audio ../public/videoml/realtime-collaboration.wav --frames out/frames/realtime-collaboration --out out/realtime-collaboration.mp4 --browser-bundle node_modules/babulus/public/babulus-standard.js --browser-bundle public/browser-components.js"
  },
  "dependencies": {
    "@kanbus/ui": "file:../packages/ui",
    "babulus": "file:../../Babulus",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@videoml/cli": "file:../../VideoML/cli",
    "esbuild": "^0.25.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
