        {
          "type": "tts",
          "startSec": 0.4,
          "endSec": 5.525,
          "text": "Kanbus is a high-level, accessible way to run Kanban directly from your repository.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/overview--overview--tts--af48571017d1--1.wav",
          "durationSec": 5.125,
          "rawDurationSec": 5.125,
          "trimEndSec": 0
        },
        {
          "type": "pause",
          "startSec": 5.525,
          "endSec": 5.7250000000000005,
          "seconds": 0.2
        },
        {
          "type": "tts",
          "startSec": 5.7250000000000005,
          "endSec": 14.100000000000001,
          "text": "You get a live board and a command line workflow, while everything stays grounded in plain files your team and AI agents can both use.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/overview--overview--tts--2e4df80ce626--1.wav",
          "durationSec": 8.375,
          "rawDurationSec": 8.375,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "git-sync",
      "cueId": "git_bus",
      "startSec": 14.100000000000001,
      "endSec": 27.975,
      "segments": [
        {
          "type": "tts",
          "startSec": 14.100000000000001,
          "endSec": 18.6875,
          "text": "Git synchronization is the core idea: use Git as the bus for Kanban boards.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/git-sync--git_bus--tts--240cdf8f2e15--1.wav",
          "durationSec": 4.5875,
          "rawDurationSec": 4.5875,
          "trimEndSec": 0
        },
        {
          "type": "pause",
          "startSec": 18.6875,
          "endSec": 18.8875,
          "seconds": 0.2
        },
        {
          "type": "tts",
          "startSec": 18.8875,
          "endSec": 27.975,
          "text": "Board updates become normal file changes, so review, history, branching, and collaboration work exactly the way your engineering team already expects.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/git-sync--git_bus--tts--ba801c4b34c0--1.wav",
          "durationSec": 9.0875,
          "rawDurationSec": 9.0875,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-cli",
      "cueId": "feature_cli",
      "startSec": 27.975,
      "endSec": 35.475,
      "segments": [
        {
          "type": "tts",
          "startSec": 27.975,
          "endSec": 35.475,
          "text": "The agent-ready CLI lets you create, update, and move work from your terminal without leaving repository-native workflows.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/feature-cli--feature_cli--tts--a4f1dd31d1f2--1.wav",
          "durationSec": 7.5,
          "rawDurationSec": 7.5,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-jira",
      "cueId": "feature_jira",
      "startSec": 35.475,
      "endSec": 43.112500000000004,
      "segments": [
        {
          "type": "tts",
          "startSec": 35.475,
          "endSec": 43.112500000000004,
          "text": "Jira synchronization brings existing Jira projects into the repo so agents and humans work from the same source of truth.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/feature-jira--feature_jira--tts--b496ee5ceba9--1.wav",
          "durationSec": 7.6375,
          "rawDurationSec": 7.6375,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-local",
      "cueId": "feature_local",
      "startSec": 43.112500000000004,
      "endSec": 50.112500000000004,
      "segments": [
        {
          "type": "tts",
          "startSec": 43.112500000000004,
          "endSec": 50.112500000000004,
          "text": "Local tasks let you draft privately and promote to the shared board only when work is ready for team visibility.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/feature-local--feature_local--tts--8553b58395a2--1.wav",
          "durationSec": 7,
          "rawDurationSec": 7,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-virtual",
      "cueId": "feature_virtual",
      "startSec": 50.112500000000004,
      "endSec": 57.225,
      "segments": [
        {
          "type": "tts",
          "startSec": 50.112500000000004,
          "endSec": 57.225,
          "text": "Virtual projects aggregate cross-repository execution into a single view for planning and delivery coordination.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/feature-virtual--feature_virtual--tts--3484558d4f93--1.wav",
          "durationSec": 7.1125,
          "rawDurationSec": 7.1125,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-beads",
      "cueId": "feature_beads",
      "startSec": 57.225,
      "endSec": 64.7875,
      "segments": [
        {
          "type": "tts",
          "startSec": 57.225,
          "endSec": 64.7875,
          "text": "Beads compatibility lets you open existing data immediately and evolve your process incrementally while teams keep shipping.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/feature-beads--feature_beads--tts--6280de542434--1.wav",
          "durationSec": 7.5625,
          "rawDurationSec": 7.5625,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-vscode",
      "cueId": "feature_vscode",
      "startSec": 64.7875,
      "endSec": 72.32499999999999,
      "segments": [
        {
          "type": "tts",
          "startSec": 64.7875,
          "endSec": 72.32499999999999,
          "text": "The VS Code plugin lets you inspect and update board state without context switching away from the files you are editing.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/feature-vscode--feature_vscode--tts--403ee7cb3f03--1.wav",
          "durationSec": 7.5375,
          "rawDurationSec": 7.5375,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-wiki",
      "cueId": "feature_wiki",
      "startSec": 72.32499999999999,
      "endSec": 80.17499999999998,
      "segments": [
        {
          "type": "tts",
          "startSec": 72.32499999999999,
          "endSec": 80.17499999999998,
          "text": "The integrated wiki renders current issue lists inside docs so plans, status updates, and execution context stay synchronized.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/intro/env/development/segments/feature-wiki--feature_wiki--tts--809a4050bc12--1.wav",
          "durationSec": 7.85,
          "rawDurationSec": 7.85,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "feature-policy",
      "cueId": "feature_policy",
