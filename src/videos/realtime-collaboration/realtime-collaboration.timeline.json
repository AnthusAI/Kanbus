          "endSec": 9.225,
          "seconds": 0.6
        },
        {
          "type": "tts",
          "startSec": 9.225,
          "endSec": 17.3875,
          "text": "Every change still writes issue JSON and an event log entry. Gossip publishes a small notification so other tools react immediately.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/realtime-collaboration/env/development/segments/deep_dive--gossip--tts--42e069634c7b--1.wav",
