          "endSec": 15.9,
          "seconds": 0.6
        },
        {
          "type": "tts",
          "startSec": 15.9,
          "endSec": 23.55,
          "text": "Watchers write a disposable overlay snapshot, so you can see updates before a pull lands. Overlay never resolves conflicts.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/realtime-collaboration/env/development/segments/deep_dive--overlay--tts--bf1385c4ee44--1.wav",
