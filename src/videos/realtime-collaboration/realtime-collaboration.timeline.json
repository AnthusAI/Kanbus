          "seconds": 0.6
        },
        {
          "type": "tts",
          "startSec": 24.150000000000002,
          "endSec": 31.700000000000003,
          "text": "Use a local Unix socket broker on one machine, or MQTT for LAN and cloud. Mosquitto can autostart locally when available.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/realtime-collaboration/env/development/segments/deep_dive--transports--tts--00f0bd14d252--1.wav",
