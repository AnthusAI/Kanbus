    },
    {
      "type": "tts",
      "sceneId": "deep_dive",
      "cueId": "overlay",
      "startSec": 17.3875,
      "endSec": 25.6625,
      "segments": [
        {
          "type": "pause",
          "startSec": 17.3875,
          "endSec": 17.9875,
          "seconds": 0.6
        },
        {
          "type": "tts",
          "startSec": 17.9875,
          "endSec": 25.6625,
          "text": "Watchers write a disposable overlay snapshot, so you can see updates before a pull lands. Overlay never resolves conflicts.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/realtime-collaboration/env/development/segments/deep_dive--overlay--tts--bf1385c4ee44--1.wav",
          "durationSec": 7.675,
          "rawDurationSec": 7.675,
          "trimEndSec": 0
        }
      ]
    },
    {
      "type": "tts",
      "sceneId": "deep_dive",
      "cueId": "transports",
      "startSec": 25.6625,
      "endSec": 33.7875,
      "segments": [
        {
          "type": "pause",
          "startSec": 25.6625,
          "endSec": 26.262500000000003,
          "seconds": 0.6
        },
        {
          "type": "tts",
          "startSec": 26.262500000000003,
          "endSec": 33.7875,
          "text": "Use a local Unix socket broker on one machine, or MQTT for LAN and cloud. Mosquitto can autostart locally when available.",
          "segmentPath": "/Users/ryan.porter/Projects/Kanbus/.videoml/out/realtime-collaboration/env/development/segments/deep_dive--transports--tts--00f0bd14d252--1.wav",
          "durationSec": 7.525,
